{
  "name": "chp-cli",
  "version": "0.1.0",
  "description": "CHP - Copilot Helper CLI Provider",
  "type": "module",
  "private": true,
  "bin": {
    "chp": "./bin/chp"
  },
  "scripts": {
    "build": "node scripts/build.ts",
    "dev": "npm run build && node dist/cli.mjs",
    "dev:profile": "node scripts/provider-launch.ts",
    "dev:profile:fast": "node scripts/provider-launch.ts auto --fast --bare",
    "profile:init": "node scripts/provider-bootstrap.ts",
    "profile:recommend": "node scripts/provider-recommend.ts",
    "start": "node dist/cli.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.6.0"
  }
}
